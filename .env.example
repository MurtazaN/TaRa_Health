# ---- Storage (local-first) ----
TARA_DATA_DIR=./.tara_data          # documents, db, and vector index live here
TARA_DB_KEY=                        # passphrase for SQLCipher (leave blank to run unencrypted in dev)

# ---- Model mode ----
# local  = always use the on-device model (private, offline)
# hosted = always use the hosted frontier model (opt-in; data leaves device)
# hybrid = local by default, escalate to hosted only when the user opts in per-query
TARA_MODEL_MODE=local

# ---- Local model (Ollama) ----
TARA_OLLAMA_HOST=http://localhost:11434
TARA_LOCAL_MODEL=qwen3:8b           # or llama3.3:8b / gemma3:12b — match your hardware

# ---- Hosted model (only used in hosted/hybrid mode) ----
TARA_HOSTED_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=

# ---- Embeddings (local) ----
TARA_EMBED_MODEL=BAAI/bge-small-en-v1.5
TARA_EMBED_DIM=384

# ---- Retrieval ----
TARA_TOP_K=6
